# -----------------------------------------------------------------------------
# CẤU HÌNH BIẾN MÔI TRƯỜNG KẾT NỐI MICROSOFT POWER BI SERVICE
# -----------------------------------------------------------------------------

# URL Nhúng của báo cáo Power BI (Embed URL)
# Bạn có thể lấy từ Power BI Service bằng cách vào Báo cáo -> File -> Embed report -> Website or portal
VITE_POWERBI_EMBED_URL="https://app.powerbi.com/reportEmbed?reportId=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx&groupId=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy&w=2&config=eyJjbHVzdGVyVXJsIjoiaHR0cHM6Ly9XQUJFLVNFLUFzaWEtUmVkaXJlY3QuYW5hbHlzaXMud2luZG93cy5uZXQifQ%3D%3D"

# ID của báo cáo Power BI (Dạng mã GUID xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
VITE_POWERBI_REPORT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ID của Workspace/Group chứa báo cáo (Tùy chọn nhưng khuyến nghị)
VITE_POWERBI_GROUP_ID="yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy"

# Access Token kết nối với Microsoft Azure AD/Power BI REST API
# LƯU Ý QUAN TRỌNG: Access Token có hạn sử dụng mặc định là 60 phút.
# Bạn cần gia hạn hoặc sử dụng một API Backend để cấp phát và tự động làm mới mã này ở môi trường production.
VITE_POWERBI_ACCESS_TOKEN="eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsIng1dCI6Imk2YmR..."

# Loại Token nhúng:
# - AAD: Dùng tài khoản người dùng Azure AD thông thường (User Owns Data - Embed for organization) - KHUYÊN DÙNG khi thử nghiệm.
# - EMBED: Dùng Service Principal / Embed Token cấp từ server (App Owns Data - Embed for customers)
VITE_POWERBI_TOKEN_TYPE="AAD"
